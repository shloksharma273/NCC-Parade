HOST=0.0.0.0
PORT=8000
DIFFICULTY=2

# ── Network / Pairing ──────────────────────────────────────────────────────
# HOST_IP pins the IP address used in QR codes and pairing URLs.
# Leave blank to let the server auto-detect (works for most setups).
# Set this explicitly if auto-detection picks the wrong interface, e.g. on
# Ethernet-only PCs (no Wi-Fi), VPN machines, or multi-NIC servers.
# Example (Ethernet-only PC):
#   HOST_IP=192.168.1.100
HOST_IP=

# Camera mode: usb | ip
CAMERA_TYPE=usb

# USB camera (when CAMERA_TYPE=usb)
USB_CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# IP camera (when CAMERA_TYPE=ip) — Secureye / generic RTSP
IP_CAMERA_HOST=192.168.1.50
IP_CAMERA_PORT=554
IP_CAMERA_USERNAME=admin
IP_CAMERA_PASSWORD=your_password

# Full RTSP URLs (recommended — confirm paths from camera vendor / VLC test)
IP_CAMERA_RTSP_MAIN=rtsp://admin:your_password@192.168.1.50:554/main
IP_CAMERA_RTSP_SUB=rtsp://admin:your_password@192.168.1.50:554/sub

# Used only if RTSP URLs above are empty (paths vary by vendor)
IP_CAMERA_MAIN_PATH=main
IP_CAMERA_SUB_PATH=sub
IP_CAMERA_ACTIVE_STREAM=main

# Recording
RECORDING_BACKEND=opencv
RECORDING_FPS=20
RECORDING_WIDTH=2560
RECORDING_HEIGHT=1440
RECORDING_FORMAT=mp4

# Preview — sub stream is lower bandwidth for tablet
PREVIEW_USE_SUBSTREAM=true
PREVIEW_REFRESH_SECONDS=1
MAX_FRAME_READ_FAILURES=30
